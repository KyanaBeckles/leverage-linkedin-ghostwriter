{
  "name": "leverage-linkedin-ghostwriter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply ghostwriter-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply ghostwriter-db --remote",
    "db:seed:local": "wrangler d1 execute ghostwriter-db --local --file=./data/seed.sql",
    "db:seed:remote": "wrangler d1 execute ghostwriter-db --remote --file=./data/seed.sql"
  },
  "devDependencies": {
    "wrangler": "^4.0.0",
    "typescript": "^5.8.2",
    "@cloudflare/workers-types": "^4.20250101.0"
  }
}
